# Optional monitor tuning. Copy to monitor.env on the backend only when needed.
PLUGINSCORE_ALERT_DISK_PCT=70
PLUGINSCORE_ALERT_MEMORY_AVAILABLE_MB=1024
PLUGINSCORE_ALERT_RUNNING_JOB_SECONDS=1800
PLUGINSCORE_ALERT_FAILED_JOBS=0
PLUGINSCORE_ALERT_QUEUED_JOBS=100
PLUGINSCORE_ALERT_CONTAINER_RESTARTS=0
PLUGINSCORE_ALERT_REPEAT_SECONDS=3600

# Optional Slack/Discord/custom webhook endpoint that accepts {"text": "..."}.
# PLUGINSCORE_ALERT_WEBHOOK_URL=

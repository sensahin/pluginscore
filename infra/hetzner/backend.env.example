# Copy to infra/hetzner/.env on the dedicated PluginScore backend host.
# Never commit the real .env file or real secrets.

# Safety rail: deploy.sh refuses to run unless this is exactly "yes".
CONFIRM_DEDICATED_PLUGINSCORE_HOST=yes

# Public API domain. Point this DNS record to the dedicated Hetzner server.
API_DOMAIN=api.pluginscore.com

# API/Postgres
POSTGRES_PASSWORD=replace-with-long-random-postgres-password
API_INTERNAL_TOKEN=replace-with-long-random-internal-token
PLUGIN_CHECK_VERSION=2.0.0
SEARCH_RATE_LIMIT_PER_MINUTE=60
SUBMISSION_RATE_LIMIT_PER_MINUTE=6
REPORT_RATE_LIMIT_PER_MINUTE=4
REPORT_IP_HASH_SECRET=replace-with-long-random-report-hash-secret

# Worker resource behavior
SCAN_IDLE_SECONDS=60
SCAN_TIMEOUT_SECONDS=600
API_BODY_LIMIT_BYTES=52428800
RUNNING_JOB_TIMEOUT_SECONDS=1800
RUNNING_JOB_MAX_ATTEMPTS=3
SCAN_RETRY_BACKOFF_SECONDS=21600
SCAN_TERMINAL_TIMEOUT_ATTEMPTS=2
EXTERNAL_CONNECTION_ANALYSIS_DISABLED=false
EXTERNAL_CONNECTION_ANALYSIS_TIMEOUT_SECONDS=15
PLUGIN_CHECK_MODE=new
PLUGIN_CHECK_CATEGORIES=
PLUGIN_CHECK_CHECKS=
PLUGIN_CHECK_EXCLUDE_CHECKS=
PLUGIN_CHECK_IGNORE_CODES=

# Scheduler
SCHEDULER_LIMIT=1000
SCHEDULER_INTERVAL_SECONDS=3600
SCHEDULER_PRIORITY=100
SCHEDULER_WATCH_TRACKED=true
SCHEDULER_TRACKED_LIMIT=5000
SCHEDULER_TRACKED_PRIORITY=80

# Scanner-only WordPress runtime.
# Do not point these at aipower.org, docs.aipower.org, or any production WordPress database.
WP_DB_PASSWORD=replace-with-long-random-wp-db-password
WP_DB_ROOT_PASSWORD=replace-with-long-random-wp-root-password
WP_ADMIN_PASSWORD=replace-with-long-random-scanner-admin-password
WP_ADMIN_EMAIL=scanner@pluginscore.local

# Web
# Set this on Vercel when the API backend exists.
PLUGINSCORE_API_URL=https://api.pluginscore.com
# Optional footer repo link. Defaults to https://github.com/sensahin/pluginscore.
NEXT_PUBLIC_GITHUB_URL=https://github.com/sensahin/pluginscore
# Optional Google Analytics 4 measurement ID for the public web app.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Optional private admin route. If PLUGINSCORE_ADMIN_PASSWORD is unset,
# /admin returns 404 and stays hidden on public deployments.
PLUGINSCORE_ADMIN_USERNAME=admin
PLUGINSCORE_ADMIN_PASSWORD=change-me-long-random-password

# API
API_HOST=0.0.0.0
PORT=4010
DATABASE_URL=postgres://pluginscore:change-me@127.0.0.1:5432/pluginscore
CORS_ORIGIN=https://pluginscore.com,http://127.0.0.1:3000
API_INTERNAL_TOKEN=change-me-long-random-token
SEARCH_RATE_LIMIT_PER_MINUTE=60
API_BODY_LIMIT_BYTES=52428800
SCAN_RETRY_BACKOFF_SECONDS=21600
SCAN_TERMINAL_TIMEOUT_ATTEMPTS=2

# Scanner
PLUGINSCORE_API_URL=http://127.0.0.1:4010
# Uses API_INTERNAL_TOKEN from the API section.
SEED_LIMIT=100
SCAN_IDLE_SECONDS=60
SCAN_TIMEOUT_SECONDS=600
SCAN_TMP_DIR=/tmp/pluginscore-scans
PLUGIN_CHECK_VERSION=2.0.0
PLUGIN_CHECK_MODE=new
PLUGIN_CHECK_CATEGORIES=
PLUGIN_CHECK_CHECKS=
PLUGIN_CHECK_EXCLUDE_CHECKS=
PLUGIN_CHECK_IGNORE_CODES=

# Command template variables: {pluginDir} {slug} {jsonPath} {tmpDir}
# The dedicated scanner image provides this wrapper.
PLUGIN_CHECK_COMMAND=/usr/local/bin/run-plugin-check {pluginDir} {jsonPath}

# Scheduler
SCHEDULER_LIMIT=1000
SCHEDULER_INTERVAL_SECONDS=3600
SCHEDULER_PRIORITY=100

# Scanner-only WordPress runtime. Do not point these at aipower.org or docs.aipower.org.
WP_PATH=/opt/wordpress
WP_DB_HOST=scanner-db:3306
WP_DB_NAME=pluginscore_wp
WP_DB_USER=wordpress
WP_DB_PASSWORD=change-me
WP_DB_ROOT_PASSWORD=change-me-too
WP_URL=http://pluginscore.local
WP_TITLE=PluginScore Scanner
WP_ADMIN_USER=pluginscore
WP_ADMIN_PASSWORD=change-me-admin
WP_ADMIN_EMAIL=scanner@pluginscore.local
